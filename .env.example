# AutoPlan – API Keys
# Kopiere diese Datei als ".env" und trage deine Keys ein.
# Die .env-Datei wird vom Server automatisch geladen.

# Google Maps (Pflicht) – Karten, Geocoding, Routenberechnung
# https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=

# OpenAI (Optional) – Dokumenten-Scan per Foto
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Lexoffice (Optional) – Kontaktsuche nach Name
# https://app.lexoffice.de/addons/public-api
LEXOFFICE_API_KEY=
